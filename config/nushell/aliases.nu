# core command line --
alias cls = clear
alias ls = ls -a

# television --
alias cc = cd (tv dirs) # cc := change channel
alias sc = hx (tv files) # sc := select channel

# cli applications --
alias book = epy
alias llm = ollama run llama3.2
alias typing = toipe
alias screensaver = tarts
alias clock = clock-rs

alias yt-music = yt-dlp -f 'bestaudio' --extract-audio --audio-format 'flac' --audio-quality 0
# alias yt-video = yt-dlp -f
