# ── Ghostty terminal — Linux configuration ────────────────────────────────────

theme = Mellow

font-family = JetBrainsMono Nerd Font
font-size = 14

cursor-style = bar
cursor-style-blink = false

window-padding-x = 10
window-padding-y = 10

shell-integration = detect
shell-integration-features = cursor,sudo,title

# Open new windows/tabs in the same working directory
window-inherit-working-directory = true

# Slightly translucent — comment out if compositor doesn't support it
# background-opacity = 0.95

# keybinds (super+backspace clears whole line)
keybind = ctrl+shift+backspace=text:\x15
